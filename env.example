APP_NAME="MEDIZEN"
APP_DESCRIPTION="RIS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ris
DB_USERNAME=root
DB_PASSWORD=

DB_SIMRS_HOST=127.0.0.1
DB_SIMRS_PORT=3306
DB_SIMRS_DATABASE=simrs_database
DB_SIMRS_USERNAME=root
DB_SIMRS_PASSWORD=

PACS_URL=http://localhost:8042
PACS_USERNAME=orthanc
PACS_PASSWORD=orthanc
# URL publik yang digunakan untuk link viewer di browser
PACS_PUBLIC_URL=http://your-pacs-public-url.com

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="admin@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# SATUSEHAT CONFIGURATION (stg / production)
SATUSEHAT_ENV=stg
SATUSEHAT_AUTH_URL=https://api-satusehat-stg.kemkes.go.id/oauth2/v1
SATUSEHAT_BASE_URL=https://api-satusehat-stg.kemkes.go.id/fhir-r4/v1

SATUSEHAT_ORGANIZATION_ID=your_org_id
SATUSEHAT_CLIENT_ID=your_client_id
SATUSEHAT_CLIENT_SECRET=your_client_secret

# DICOM ROUTER CONFIG
DICOM_ROUTER_MODALITY=DCMROUTER
